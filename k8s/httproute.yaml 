
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: wordpress
  namespace: blog
spec:
  hostnames:
    - cslab.cloudsecuritylab.co.kr
  parentRefs:
    - name: cilium
      namespace: kube-system
  rules:
    # 1. /hangul-play 경로 처리
    - matches:
      - path:
          type: PathPrefix  # path 아래로 들여쓰기
          value: /hangul-play # path 아래로 들여쓰기
      filters:
        - type: URLRewrite
          urlRewrite:
            path:
              type: ReplacePrefixMatch
              replacePrefixMatch: /
      backendRefs:
      - group: ""
        kind: Service
        name: hangul-play-svc
        port: 80
        weight: 1
        
    # 2. 그 외 나머지 트래픽 (/) 처리
    - matches:
      - path:
          type: PathPrefix  # path 아래로 들여쓰기
          value: /          # path 아래로 들여쓰기
      backendRefs:
      - group: ""
        kind: Service
        name: wordpress
        port: 80
        weight: 1